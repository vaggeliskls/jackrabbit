# ── Server ────────────────────────────────────────────
SERVER_PORT=8080
SERVER_ENV=development

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=runnerdb
POSTGRES_USER=runner
POSTGRES_PASSWORD=secret
POSTGRES_MAX_CONNS=20
POSTGRES_QUEUE_POLL_INTERVAL_MS=500

# ── Retention — Logs ──────────────────────────────────
LOG_RETENTION_DAYS_SYSTEM=7
LOG_RETENTION_DAYS_COMMAND=30
LOG_RETENTION_SIZE_MB_COMMAND=100

# ── Retention — Metrics ───────────────────────────────
METRIC_RETENTION_DAYS_RAW=1
METRIC_RETENTION_DAYS_1M=7
METRIC_RETENTION_DAYS_5M=30

# ── Workers ───────────────────────────────────────────
REAPER_INTERVAL_SECS=30
RUNNER_ORPHAN_THRESHOLD_SECS=90
COMMAND_ORPHAN_DEADLINE_SECS=300
RETENTION_INTERVAL_SECS=3600
ROLLUP_INTERVAL_SECS=300

# ── Traefik ───────────────────────────────────────────
TRAEFIK_API_TOKEN=secret
