# Runner Configuration

# Server connection
CLIENT_SERVER_URL=http://localhost:80
CLIENT_API_TOKEN=secret

# Runner identification
CLIENT_RUNNER_SLUG=my-runner-01
CLIENT_RUNNER_NAME=My Development Runner
CLIENT_RUNNER_TAGS=dev,linux,docker

# Resource limits
CLIENT_MAX_CONCURRENCY=4
CLIENT_GPU_CAPABLE=false

# Batching and intervals (milliseconds for batch intervals, seconds for heartbeat)
CLIENT_LOG_BATCH_INTERVAL_MS=500
CLIENT_METRIC_SAMPLE_INTERVAL_MS=1000
CLIENT_METRIC_BATCH_SIZE=50
CLIENT_HEARTBEAT_INTERVAL_SECS=30

# TLS configuration (optional)
CLIENT_TLS_SKIP_VERIFY=false
CLIENT_CA_CERT_PATH=

# Environment
ENV=development
